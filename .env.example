# ============================================================================
# Hydra Trading System — Environment Variables
# ============================================================================

# --- Telegram ---
HYDRA_TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE
HYDRA_ADMIN_CHAT_ID=YOUR_ADMIN_CHAT_ID_HERE
HYDRA_SIGNAL_CHANNEL_ID=0

# --- Database ---
HYDRA_DATABASE_URL=postgresql://hydra:hydra_pass@localhost:5432/hydra_trading

# --- Server ---
HYDRA_SERVER_HOST=0.0.0.0
HYDRA_SERVER_PORT=8788
HYDRA_DEBUG=false

# --- Master Source ---
HYDRA_MASTER_SOURCE=HERMES
HYDRA_DEFAULT_MAGIC=20260527
